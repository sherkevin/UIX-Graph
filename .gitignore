# =============================================================================
# UIX-Graph .gitignore
#
# 维护原则:
# 1. 严禁入库:运行时产物 / 缓存 / 部署包 / 工具私有目录 / 个人凭证
# 2. 必须入库:.env.example、.cursor/rules/*.mdc、deploy/、docker/、scripts/
# 3. 想新加忽略项前,先确认是「所有人都不该入库」,否则用 .git/info/exclude
# =============================================================================

# ---------------- Python ----------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.db
*.sqlite
*.sqlite3
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---------------- Node / Frontend ----------------
node_modules/
dist/
build/
.vite/
src/frontend/.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------- Logs / Runtime ----------------
*.log
backendstacks.log
logs/
*.pid
*.seed

# ---------------- Environment files ----------------
# 由 scripts/switch_env.py 生成,绝不入库
src/backend/.env
src/frontend/.env
.env
.env.local
.env.*.local
# 示例文件保留
!src/backend/.env.example
!src/frontend/.env.example
!.env.example

# ---------------- 部署产物 / 打包 zip ----------------
# scripts/package_intranet.ps1 输出物
UIX-Graph-intranet-package*.zip
*.zip
*.tar.gz
*.tgz

# ---------------- IDE / 工具私有 ----------------
.vscode/
.idea/
.fleet/
*.swp
*.swo
*~
# Cursor IDE:仅忽略本地状态,保留 .cursor/rules/* 与 .cursor/mcp.json 入库
.cursor/cache/
.cursor/local/
# Claude / SpecStory / Codex 等插件本地状态
.claude/
.codex/
.specstory/

# ---------------- Cursor 聊天 / 草稿临时文件 ----------------
cursor_*.md
*.bak
*.tmp
*.orig
*.rej

# ---------------- OS ----------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------- 中文文件名(避免 Windows/Linux 编码冲突) ----------------
# 这一类文件名容易在 git/zip/CI 上踩坑;
# 如确需中文文档,请放在 docs/ 下并用英文命名
内网迁移指南.md
