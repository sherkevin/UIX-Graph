              {
                "compare": {
                  "left": "rotation_3sigma",
                  "operator": ">",
                  "right": 350
                }
              }
            ]
          }
        },
        {
          "target": "2",
          "condition": "else"
        }
      ]
    },
    {
      "id": "2",
      "description": "检查真空吸附异常",
      "next": [
        {
          "target": "102",
          "condition": {
            "all_of": [
              {
                "compare": {
                  "left": "vacuum_level",
                  "operator": "==",
                  "right": "Low"
                }
              },
              {
                "compare": {
                  "left": "rotation_mean",
                  "operator": ">",
                  "right": 100
                }
              }
            ]
          }
        },
        {
          "target": "199",
          "condition": "else"
        }
      ]
    },
    {
      "id": "101",
      "result": {
        "rootCause": "上片旋转机械超限",
        "system": "机械精度",
        "category": "机械精度",
        "confidence": 85,
        "reasoning": [
          "检测到旋转参数超出阈值",
          "rotation_mean > 300 urad 或 rotation_3sigma > 350",
          "判定为上片旋转机械超限"
        ]
      }
    },
    {
      "id": "102",
      "result": {
