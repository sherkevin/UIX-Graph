  "diagnosis_scenes": [
    {
      "id": "ontology-default",
      "module": "ontology",
      "phenomenon": "通用故障诊断",
      "description": "用于 /api/diagnosis 的配置化诊断入口",
      "default": true,
      "start_node": "1"
