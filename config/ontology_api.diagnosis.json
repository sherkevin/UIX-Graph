        "category": "硬件损耗",
        "confidence": 85,
        "reasoning": [
          "检测到真空度低且旋转异常",
          "vacuum_level = Low 且 rotation_mean > 100",
          "判定为 WS 硬件物理损坏/泄露"
        ]
      }
    },
    {
      "id": "199",
