      "metric_id": "n_88um",
      "details": null,
      "next": [
        {
          "target": "21",
          "condition": "n_88um≤8",
          "operator": "≤",
          "limit": 8
        },
        {
          "target": "99",
          "condition": "n_88um>8",
          "operator": ">",
          "limit": 8
        }
      ]
