  "diagnosis_scenes": [
    {
      "id": 1001,
      "module": "COWA",
      "phenomenon": "倍率超限",
      "description": "COWA倍率超限，补偿建模",
      "metric_id": [
        "trigger_reject_reason_cowa_6",
        "trigger_log_mwx_cgg6_range"
      ],
      "trigger_condition": [
        "{trigger_reject_reason_cowa_6} == true AND {trigger_log_mwx_cgg6_range} == true"
      ],
      "start_node": "1"
    }
  ],
  "steps": [
    {
      "id": 1,
      "description": "判断M值及输出模型类型",
      "metric_id": "Mwx_0",
      "details": [
        {
          "action": "select_window_metric",
          "description": "从窗口列表中选择距离T最近的Mwx_0供后续判断",
          "params": {
            "metric_name": "Mwx_0",
            "values": "{Mwx_0}"
          },
          "results": {
            "Mwx_0": ""
          }
        },
        {
          "action": "determine_model_type",
          "description": "根据Mwx_0范围自动判断并输出model_type",
          "params": null,
          "results": {
            "model_type": ""
          }
        }
      ],
      "next": [
        {
          "target": "10",
          "condition": "{Mwx_0} > 1.0001",
          "set": {
            "model_type": "88um"
          }
        },
        {
          "target": "10",
          "condition": "{Mwx_0} < 0.9999",
          "set": {
            "model_type": "88um"
          }
        },
        {
          "target": "11",
          "condition": "1.00002 < {Mwx_0} < 1.0001",
          "set": {
            "model_type": "8um"
          }
        },
        {
          "target": "11",
          "condition": "0.9999 < {Mwx_0} < 0.99998",
          "set": {
            "model_type": "8um"
          }
        },
        {
          "target": "99",
          "condition": "else"
        }
      ]
    },
    {
      "id": 10,
      "description": "建立88微米模型",
      "details": [
        {
          "action": "build_88um_model",
          "description": "88um补偿建模",
          "params": {
            "ws_pos_x": "",
            "ws_pos_y": "",
            "mark_pos_x": "",
            "mark_pos_y": "",
            "Msx": "",
            "Msy": "",
            "e_ws_x": "",
            "e_ws_y": "",
            "Sx": "",
            "Sy": "",
            "D_x": "",
            "D_y": ""
          },
          "results": {
            "n_88um": "",
            "output_Tx": "",
            "output_Ty": "",
            "output_Rw": "",
            "output_Mw": ""
          }
        }
      ],
      "next": [
        {
          "target": "20",
          "condition": ""
        }
      ]
    },
    {
      "id": 11,
      "description": "建立8微米模型",
      "details": [
        {
          "action": "build_8um_model",
          "description": "8um补偿建模",
          "params": {
            "ws_pos_x": "",
            "ws_pos_y": "",
            "mark_pos_x": "",
            "mark_pos_y": "",
            "Msx": "",
            "Msy": "",
            "e_ws_x": "",
            "e_ws_y": "",
            "Sx": "",
            "Sy": "",
            "D_x": "",
            "D_y": ""
          },
          "results": {
            "n_88um": "",
            "output_Tx": "",
            "output_Ty": "",
            "output_Rw": "",
            "output_Mw": ""
          }
        }
      ],
      "next": [
        {
          "target": "20",
          "condition": ""
        }
      ]
    },
    {
      "id": 20,
      "description": "检查补偿建模次数(若 n_88um 缺失会落 else,送人工处理)",
      "metric_id": "n_88um",
      "next": [
        {
          "target": "21",
          "condition": "{n_88um} <= 8"
        },
        {
          "target": "99",
          "condition": "{n_88um} > 8"
        },
        {
          "target": "99",
          "condition": "else"
        }
      ]
    },
    {
      "id": 21,
      "description": "检查COWA建模结果的倍率是否正常",
      "metric_id": "output_Mw",
      "details": null,
      "next": [
        {
          "target": [
            "22",
            "23",
            "24"
          ],
          "condition": "-20 < {output_Mw} < 20"
        },
        {
          "target": "continue_model",
          "condition": "else"
        }
      ]
    },
    {
      "id": "continue_model",
      "description": "继续建模",
      "details": null,
      "next": [
        {
          "target": "99",
          "condition": "{n_88um} >= 8"
        },
        {
          "target": "continue_model_dispatch",
          "condition": "else"
        }
      ]
    },
    {
      "id": "continue_model_dispatch",
      "description": "按模型类型选择下一轮建模",
      "details": null,
      "next": [
        {
          "target": "10",
          "condition": "{model_type} == '88um'"
        },
        {
          "target": "11",
          "condition": "{model_type} == '8um'"
        },
        {
          "target": "10",
          "condition": "else"
        }
      ]
    },
    {
      "id": 22,
      "description": "检查上片偏差Tx",
      "metric_id": "Tx",
      "next": [
        {
          "target": "221",
          "condition": "-20 < {output_Tx} < 20"
        },
        {
          "target": "30",
          "condition": "else"
        }
      ]
    },
    {
      "id": 221,
      "description": "Tx正常，normal_count + 1",
