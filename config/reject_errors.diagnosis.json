    {
      "id": 1,
      "description": "判断M值及输出模型类型",
      "metric_id": "Mwx_0",
      "details": [
        {
          "action": "determine_model_type",
          "description": "根据Mwx_0范围自动判断并输出model_type",
          "params": null,
          "results": {
            "model_type": ""
          }
        }
      ],
      "next": [
        {
          "target": "10",
          "condition": "{Mwx_0} > 1.0001",
          "operator": ">",
          "limit": 1.0001,
          "set": {
            "model_type": "88um"
          }
        },
        {
          "target": "10",
          "condition": "{Mwx_0} < 0.9999",
          "operator": "<",
          "limit": 0.9999,
          "set": {
            "model_type": "88um"
          }
        },
        {
          "target": "11",
          "condition": "1.00002 < {Mwx_0} < 1.0001",
          "operator": "between",
          "limit": [
            1.00002,
            1.0001
          ],
          "set": {
            "model_type": "8um"
          }
        },
        {
          "target": "11",
          "condition": "0.9999 < {Mwx_0} < 0.99998",
          "operator": "between",
          "limit": [
            0.9999,
            0.99998
          ],
          "set": {
            "model_type": "8um"
          }
        },
        {
          "target": "99",
          "condition": "else"
        }
      ]
    },
