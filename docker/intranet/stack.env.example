# Portainer Stack 环境变量示例
# 使用前复制为评审/部署环境的实际变量，敏感信息不要提交 git。

# 172.16.70.160 直接使用本机 Docker 镜像时，使用普通本地命名空间即可。
# 如需推送 Harbor/Nexus，填写完整仓库命名空间，例如 harbor.example.com/uix。
UIX_IMAGE_NAMESPACE=uix-graph

# 每次评审/发布必须使用明确版本号，不允许 latest。
UIX_IMAGE_TAG=v1.0.0-review

# 172.16.70.160 上项目仓库所在绝对路径，用于只读挂载 config。
UIX_PROJECT_DIR=/home/uix/UIX-Graph

# 后端运行环境：应与 config/connections.json 中的键一致。
APP_ENV=prod
METRIC_SOURCE_MODE=real
REJECTED_DETAILED_CACHE=0
UIX_DETAIL_TRACE=0
LOG_LEVEL=INFO

# 同源部署时填写前端访问地址；多个来源用逗号分隔。
CORS_ORIGINS=http://172.16.70.160

# Portainer/宿主机暴露端口。
FRONTEND_EXTERNAL_PORT=80
BACKEND_EXTERNAL_PORT=8000
