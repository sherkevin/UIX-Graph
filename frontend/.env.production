# API Base URL
VITE_API_BASE_URL=/api

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true

# Graph Configuration
VITE_GRAPH_MAX_NODES=2000
VITE_GRAPH_DEFAULT_LAYOUT=force
VITE_GRAPH_ANIMATION_DURATION=300

# Cache Configuration
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=600000

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_DEFAULT_LANGUAGE=zh-CN
