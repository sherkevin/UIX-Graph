# ============================================================
# 后端环境变量示例
# 使用方式（二选一）：
#   1. 复制为 .env 并手动填写
#   2. 运行 scripts/switch_env.py [local|test|prod] 自动生成
# ============================================================

# 数据库环境选择，对应 config/connections.json 中的键
# 可选值：local（默认）、test、prod
APP_ENV=local

# ── CORS ────────────────────────────────────────────────────
# 允许的前端来源（逗号分隔，不含尾部 /）
# 外网同源反代部署时填写代理域名，例如 https://rca.example.com
# 本地开发：留空则使用默认 localhost 白名单
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── 数据源模式（接口3诊断引擎） ──────────────────────────────
# real           - 所有指标必须来自真实数据源，ClickHouse 不通则抛错
# mock_allowed   - 真实数据源不通时允许降级为 mock（默认联调模式）
# mock_forbidden - 禁止 mock，用于外网验收阶段明确要求真实数据
METRIC_SOURCE_MODE=mock_allowed

# ── 日志级别 ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 老路由开关 ───────────────────────────────────────────────
# 默认 true: 注册 /api/{ontology,knowledge,diagnosis,visualization,
# propagation,entity,graph} 7 组老图谱/本体路由(stage3 之前的能力)
# 设 false: 屏蔽这 7 组路由,仅保留 /api/v1/reject-errors;
#           内网若已确认无第三方调用方,可设 false 30 天观察访问日志,
#           确认无 404 后再后续 PR 物理删除 handler/core/对应测试。
# /api/v1/reject-errors 不受本开关影响,始终注册。
LEGACY_ROUTES_ENABLED=true
