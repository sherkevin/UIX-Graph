# ============================================================
# 外网部署环境变量模板
# 复制为 .env 并按实际填写后再启动后端
# ============================================================

APP_ENV=prod

# 外网前端域名（同源反代时与前端同域，填写代理根域名）
CORS_ORIGINS=https://your-external-domain.com

# 外网联调阶段：允许 mock，待内网 ClickHouse 接通后改为 real
METRIC_SOURCE_MODE=mock_allowed

LOG_LEVEL=INFO
