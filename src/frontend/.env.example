# ============================================================
# 前端环境变量示例
# 使用方式（二选一）：
#   1. 复制为 .env 并手动填写
#   2. 运行 scripts/switch_env.py [local|test|prod] 自动生成
# ============================================================

# ── API 根路径 ───────────────────────────────────────────────
# 空值：前端请求 /api 会走 Vite 代理或同源反代（推荐）
# 绝对 URL：直连后端，需要后端 CORS 放行
#   例：VITE_API_BASE_URL=http://172.16.70.171:8000
VITE_API_BASE_URL=

# ── 调试开关 ─────────────────────────────────────────────────
# true: 控制台输出 API 请求详情；production 构建默认关闭
VITE_ENABLE_DEBUG=false
