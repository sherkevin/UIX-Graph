# ============================================================
# 前端生产构建环境变量模板
# 复制为 .env.production 后执行 npm run build
# ============================================================

# 同源反代部署（推荐）：VITE_API_BASE_URL 留空，
# Nginx/网关将 /api/* 转发到后端 :8000
VITE_API_BASE_URL=

# 生产环境关闭调试日志
VITE_ENABLE_DEBUG=false
